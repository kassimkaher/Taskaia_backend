DATABASE_URL=postgresql://user:password@localhost:5432/taskaia
PORT=3000
NODE_ENV=development
MOCK_MODE=false

# AI extraction + STT (Groq is the default provider for both transcription
# and the structured extraction call. Whisper / Google STT are alternatives.)
STT_PROVIDER=groq
GROQ_API_KEY=
OPENAI_API_KEY=

# Active task provider (trello | jira) — overridden per-user from the mobile app
TASK_PROVIDER=trello

# Trello — values come from the mobile Settings screen.
TRELLO_API_KEY=
TRELLO_TOKEN=
TRELLO_BOARD_ID=
TRELLO_LIST_ID=

# Jira (Atlassian Cloud)
# Host is shared across the team; the per-user fields (email, API token,
# project key, board id) are entered in the mobile Settings screen and
# saved through PUT /api/settings.
JIRA_HOST=starsphere-iq.atlassian.net
